{
  "manifest_version": 3,
  "name": "LLM Speed Monitor",
  "version": "2.1.0",
  "description": "Measures Time to First Word, Words/sec and more for ChatGPT, Claude, and Perplexity responses.",
  "permissions": [
    "storage"
  ],
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://perplexity.ai/*",
        "*://www.perplexity.ai/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "LLM Speed Monitor",
    "default_popup": "popup.html"
  }
}
